COMPOSE_PROJECT_NAME=doc-hub

# Entropy local Postgres
ENTROPY_POSTGRES_DB=postgres
ENTROPY_POSTGRES_USER=postgres
ENTROPY_POSTGRES_PASSWORD=postgres
ENTROPY_MAIL_HOST=mailhog
ENTROPY_MAIL_PORT=1025

# Redash stack
REDASH_VERSION=25.8.0
REDASH_SECRET_KEY=change-me-before-first-run
REDASH_COOKIE_SECRET=change-me-before-first-run
REDASH_POSTGRES_DB=redash
REDASH_POSTGRES_USER=postgres
REDASH_POSTGRES_PASSWORD=postgres
REDASH_WEB_WORKERS=2
REDASH_EXPORT_API_KEY=
REDASH_EXPORT_DASHBOARD=BAZ | CAPTACION MOCK
REDASH_EXPORT_RECIPIENTS=stakeholders@local.test
REDASH_EXPORT_SENDER=Redash Export <redash@local.test>
REDASH_EXPORT_MAILHOST_URL=smtp://mailhog:1025
REDASH_EXPORT_RENDER_DELAY=2
REDASH_EXPORT_NAVIGATION_TIMEOUT=300

# Optional external SQL Server connection used by dashboards/queries.
# Leave blank if you do not need it in your local clone.
SQLSERVER_HOST=
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=
SQLSERVER_USERNAME=
SQLSERVER_PASSWORD=
SQLSERVER_DRIVER=ODBC Driver 18 for SQL Server
